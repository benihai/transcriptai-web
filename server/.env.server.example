# ====== TranscriptAI Server — .env ======
# העתק קובץ זה לשם ".env" בתיקייה הראשית של הפרויקט (/opt/transcriptai/.env)
# ומלא את הערכים.

# --- Gemini (סיכום) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT=120
GEMINI_MAX_OUTPUT_TOKENS=16384

# --- Whisper (תמלול) ---
WHISPER_MODEL=ivrit-ai/whisper-large-v3-turbo-ct2
WHISPER_LANGUAGE=he
WHISPER_BEAM_SIZE=1
# WHISPER_CPU_THREADS=4   # ברירת מחדל: מחצית ליבות הCPU

# --- התראות מייל ---
NOTIFY_EMAIL=bnim4444@gmail.com              # לאן לשלוח את הסיכום
NOTIFY_SMTP_USER=bot_transcriptai@gmail.com  # ממי (Gmail ששולח)
NOTIFY_SMTP_PASS=xxxx xxxx xxxx xxxx         # Gmail App Password של החשבון השולח
                                              # (לא הסיסמה הרגילה!)
                                              # כיצד ליצור: myaccount.google.com -> Security -> App Passwords
